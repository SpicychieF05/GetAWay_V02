rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Global Safety Net ───────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── Helper functions ─────────────────────────────────────────────────────
    function isSignedIn()    { return request.auth != null; }
    function incoming()      { return request.resource.data; }
    function existing()      { return resource.data; }

    // Security: All subcollection helpers are module-level to eliminate
    // duplicate get() calls across candidateSessions, alerts, webrtc, and ICE
    // collections. Each get() is a billed Firestore read.
    function isRoomOwner(roomId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/rooms/$(roomId)).data.recruiterId == request.auth.uid;
    }

    function isRoomCandidate(roomId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/rooms/$(roomId)).data.candidateUid == request.auth.uid;
    }

    function isRoomActive(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId)).data.status != 'ended';
    }

    // ─── Recruiter Profiles ───────────────────────────────────────────────────
    // Security Architecture §7: recruiter doc scoped to matching Firebase UID.
    match /recruiters/{uid} {
      allow read:  if isSignedIn() && request.auth.uid == uid;
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // ─── Interview Rooms ──────────────────────────────────────────────────────
    match /rooms/{roomId} {
      allow read: if isRoomOwner(roomId) || isRoomCandidate(roomId);

      // Security: recruiterId is set by the Admin SDK at creation; candidates
      // have no create or delete permissions. Room status is recruiter-only.
      allow create, delete: if false;

      allow update: if
        isRoomOwner(roomId) &&
        incoming().diff(existing()).affectedKeys()
          .hasOnly(['status', 'updatedAt', 'trustScore']);

      // ─── Candidate Sessions ───────────────────────────────────────────────
      // Security Architecture §10: "Consent must be recorded server-side."
      // All writes are Admin SDK only. Client write is explicitly denied.
      match /candidateSessions/{sessionId} {
        allow read:             if isRoomOwner(roomId) || isRoomCandidate(roomId);
        allow create:           if false;
        allow update, delete:   if false;
      }

      // ─── Alerts ───────────────────────────────────────────────────────────
      // Security Architecture §7: "Alerts: only room owner can read;
      // AI system writes via Admin SDK."
      // Candidates can no longer create alerts directly — false alert injection
      // is a CRITICAL risk (poisoned hiring reports).
      match /alerts/{alertId} {
        allow read:             if isRoomOwner(roomId);
        allow create:           if false;
        allow update, delete:   if false;
      }

      // ─── Trust Logs ───────────────────────────────────────────────────────
      // Security Architecture §8: "TrustLogs can only be APPENDED by the
      // server via Admin SDK. TrustLogs can only be READ by the recruiter."
      // Trust scores are an immutable audit trail for employment decisions.
      match /trustLogs/{logId} {
        allow read:             if false;
        allow write:            if false;
      }

      // ─── Reports ──────────────────────────────────────────────────────────
      // Security Architecture §8: "Reports can only be WRITTEN by the server
      // at session end. Reports can only be READ by the recruiter who owns
      // the room."
      match /reports/{reportId} {
        allow read:             if false;
        allow write:            if false;
      }

      // ─── WebRTC Signaling (Offer / Answer) ────────────────────────────────
      // Both room participants need read/write during SDP negotiation only.
      // Signaling is blocked once the room is ended.
      match /webrtc/{nodeId} {
        allow read:           if isRoomOwner(roomId) || isRoomCandidate(roomId);
        allow create, update: if (isRoomOwner(roomId) || isRoomCandidate(roomId)) && isRoomActive(roomId);
        allow delete:         if isRoomOwner(roomId);
      }

      // ─── ICE Candidates: Caller (Recruiter → Candidate) ───────────────────
      match /callerCandidates/{candidateId} {
        allow read:           if isRoomOwner(roomId) || isRoomCandidate(roomId);
        allow create:         if isRoomOwner(roomId);
        allow update, delete: if false;
      }

      // ─── ICE Candidates: Callee (Candidate → Recruiter) ───────────────────
      match /calleeCandidates/{candidateId} {
        allow read:           if isRoomOwner(roomId) || isRoomCandidate(roomId);
        allow create:         if isRoomCandidate(roomId);
        allow update, delete: if false;
      }
    }

    // ─── Analytics ────────────────────────────────────────────────────────────
    // Architecture Analysis §analytics: future pre-computed metrics written by
    // Cloud Functions. All client access is denied; reads go via the API layer.
    match /analytics/{docId} {
      allow read, write: if false;
    }

    // ─── OTP Codes ───────────────────────────────────────────────────────────
    // Server-only collection — never accessible from any client.
    match /otpCodes/{email} {
      allow read, write: if false;
    }
  }
}
